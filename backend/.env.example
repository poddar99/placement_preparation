# Application
APP_NAME=PlacementPilot AI
DEBUG=false
API_PREFIX=/api

# Database (async URL for FastAPI)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/placementpilot

# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/placementpilot

# JWT Authentication
SECRET_KEY=change-me-in-production-use-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi2
OLLAMA_EMBEDDING_MODEL=phi2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=interview_experiences

# CORS (comma-separated origins, use * for dev)
CORS_ORIGINS=["*"]

# File Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10